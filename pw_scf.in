&CONTROL
    calculation   = 'scf'
    prefix        = 'ddh'
    outdir        = './'
    pseudo_dir    = '../pseudo/'
    tprnfor       = .true.
/

&SYSTEM
    ibrav         = 0             
    nat           = 8             
    ntyp          = 2             

    input_dft     = 'PBE0'
    exx_fraction  = 0.25
    exxdiv_treatment = 'gygi-baldereschi'

    ecutfock      = 100.0    
    ecutwfc       = 80.0          
    ecutrho       = 320.0         
    
    nosym             = .true.
    nbnd              = 400
/

&ELECTRONS
    conv_thr       = 1.0d-8
    mixing_beta    = 0.7
    diago_full_acc = .true.
    electron_maxstep = 200
/

